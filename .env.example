# Server Configuration
PORT=3232
BASE_URI=http://localhost:3232

# Auth Mode Configuration
# Options: 'internal' or 'external'
#
# - internal: Run auth server in-process (suitable for demo/development)
# - external: Use external auth server (production pattern)
#
AUTH_MODE=internal

# External Auth Server URL (required if AUTH_MODE=external)
AUTH_SERVER_URL=http://localhost:3001

# Auth0 Configuration (required)
# Register an application at https://manage.auth0.com
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# AUTH0_AUDIENCE=  # optional API audience

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_TLS=0

# Postgres Configuration
# docker compose maps Postgres to port 5433 to avoid conflicts with local installs
DATABASE_URL=postgresql://mcp_app:mcp_dev_password@localhost:5433/mcp
POSTGRES_PASSWORD=mcp_dev_password

NODE_ENV=development
